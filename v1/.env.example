PORT=5180

# Comma-separated hosts for API worker (loopback denied unless EXECUTOR_ALLOW_LOOPBACK=true)
EXECUTOR_ALLOWLIST=api.example.com,httpbin.org
EXECUTOR_ALLOW_LOOPBACK=false

# Optional durable store path (default: v1/.data/runs)
# V1_DATA_DIR=/absolute/path/to/runs

# Model routing (documentation / future LLM stages)
V1_ORCHESTRATOR_MODEL=claude-fable-5
V1_WORKER_MODEL=claude-4.6-sonnet
