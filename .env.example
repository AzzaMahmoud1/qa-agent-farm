# Agent 1 uses the Cursor Agent CLI (cursor-agent -p), authenticated via `cursor-agent login`.
# Routes through Cursor's endpoints (not api.anthropic.com). ANTHROPIC_API_KEY is not used.
# Optional: point at a specific cursor-agent binary
# CURSOR_AGENT_BIN=/path/to/cursor-agent
# Agent 1 model + reasoning effort (defaults: claude-sonnet-5 / high). Effort: low|medium|high|xhigh|max
# ANALYST_MODEL=claude-sonnet-5
# ANALYST_EFFORT=high

JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=you@company.com
JIRA_API_TOKEN=your_api_token

# Comma-separated hosts allowed for /api/execute (loopback denied unless EXECUTOR_ALLOW_LOOPBACK=1)
EXECUTOR_ALLOWLIST=api.example.com,staging.example.com
# EXECUTOR_ALLOW_LOOPBACK=1
# EXECUTE_API_TOKEN=change-me
# EXECUTE_RATE_LIMIT=10
# EXECUTE_RATE_WINDOW_MS=60000

# Optional server tuning
# PORT=5173
# HOST=127.0.0.1
# MAX_BODY_BYTES=1048576
# JIRA_TIMEOUT_MS=15000
# EXECUTE_TIMEOUT_MS=15000
